# Server Configuration
PORT=3000

# Vonage SMS Configuration (formerly Nexmo)
VONAGE_API_KEY=your_vonage_api_key_here
VONAGE_API_SECRET=your_vonage_api_secret_here
VONAGE_FROM_NUMBER=Ecovera

# Database Configuration (SQLite)
# No additional config needed - uses ecovera.db in project root

# Development Mode
# If Vonage credentials are not set, the app will run in dev mode
# OTPs will be logged to console instead of being sent via SMS
